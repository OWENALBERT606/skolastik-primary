generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Role {
  id          String   @id @default(cuid())
  displayName String
  roleName    String   @unique
  description String?
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
  users       User[]   @relation("UserRoles")

  @@index([roleName])
}

model User {
  id                       String                        @id @default(cuid())
  name                     String
  firstName                String
  lastName                 String
  phone                    String                        @unique
  email                    String?                       @unique
  emailVerified            DateTime?
  image                    String?
  jobTitle                 String?
  bio                      String?
  password                 String?
  status                   Boolean                       @default(true)
  isVerfied                Boolean                       @default(false)
  token                    String?
  userType                 UserType                      @default(SCHOOL_ADMIN)
  loginId                  String?
  schoolId                 String?
  failedLoginAttempts      Int                           @default(0)
  lockedUntil              DateTime?
  lastLoginAt              DateTime?
  lastLoginIp              String?
  createdAt                DateTime                      @default(now())
  updatedAt                DateTime                      @default(now())
  roleId                   String?
  accounts                 Account[]
  appNotifications         AppNotification[]             @relation("AppNotifications")
  attendanceEntries        AttendanceRecord[]            @relation("AttendanceEnteredBy")
  bursaryApprovals         BursaryAllocation[]           @relation("BursaryAllocationApprovedBy")
  configUnlocks            ClassAssessmentConfig[]       @relation("ConfigUnlockedBy")
  disciplinaryClosures     DisciplinaryRecord[]          @relation("DisciplinaryClosedBy")
  employmentHistoryActions EmploymentHistory[]           @relation("HistoryPerformedBy")
  transfersMade            EnrollmentTransferHistory[]
  eventRsvps               EventRSVP[]                   @relation("EventRSVPs")
  examMarkApprovals        ExamMark[]                    @relation("ExamMarkApprovedBy")
  examMarkCTApprovals      ExamMark[]                    @relation("ExamMarkClassTeacherApproved")
  exitsApproved            ExitRecord[]                  @relation("ExitApprovedBy")
  exitInterviewsConducted  ExitRecord[]                  @relation("ExitInterviewBy")
  expensesApproved         Expense[]                     @relation("ExpenseApprovedBy")
  expensesCreated          Expense[]                     @relation("ExpenseCreatedBy")
  feeNotifications         FeeNotification[]             @relation("FeeNotificationCreatedBy")
  feeTransactions          FeeTransaction[]              @relation("FeeTransactionCreatedBy")
  installmentPlans         InstallmentPlan[]             @relation("InstallmentPlanCreatedBy")
  invoicesCreated          Invoice[]                     @relation("InvoiceCreatedBy")
  invoicesVoided           Invoice[]                     @relation("InvoiceVoidedBy")
  leavesApproved           LeaveRequest[]                @relation("LeaveApprovedBy")
  auditLogs                MarkAuditLog[]
  messagesCreated          Message[]                     @relation("MessageCreatedBy")
  messageDeliveries        MessageDelivery[]             @relation("MessageDeliveries")
  notificationPrefs        NotificationPreference[]      @relation("UserNotificationPrefs")
  overtimesApproved        OvertimeRequest[]             @relation("OvertimeApprovedBy")
  parent                   Parent?
  batchesApproved          PayrollBatch[]                @relation("BatchApprovedBy")
  batchesPrepared          PayrollBatch[]                @relation("BatchPreparedBy")
  projectWorksUploaded     ProjectWork[]                 @relation("ProjectWorkUploadedBy")
  advancesApproved         SalaryAdvance[]               @relation("AdvanceApprovedBy")
  schoolAdmins             School[]                      @relation("SchoolAdmin")
  eventsCreated            SchoolEvent[]                 @relation("EventCreatedBy")
  sessions                 Session[]
  staffProfiles            Staff[]                       @relation("StaffUser")
  contractsIssued          StaffContract[]               @relation("ContractIssuedBy")
  documentsUploaded        StaffDocument[]               @relation("DocumentUploadedBy")
  documentsVerified        StaffDocument[]               @relation("DocumentVerifiedBy")
  loansApproved            StaffLoan[]                   @relation("LoanApprovedBy")
  statutoryGenerated       StatutoryReport[]             @relation("StatutoryGeneratedBy")
  stockMovementsPerformed  StockMovement[]               @relation("MovementPerformedBy")
  storesManaged            Store[]                       @relation("StoreManager")
  assignmentsCreated       StreamSubjectTeacher[]        @relation("AssignmentCreatedBy")
  reassignmentsPerformed   StreamSubjectTeacherHistory[] @relation("ReassignedBy")
  student                  Student?
  markedAttendances        StudentAttendance[]           @relation("AttendanceMarkedBy")
  systemMessagePosts       SystemMessagePost[]           @relation("SystemMessagePosts")
  teacher                  Teacher?
  trainingsCreated         TrainingProgram[]             @relation("TrainingCreatedBy")
  school                   School?                       @relation("SchoolUsers", fields: [schoolId], references: [id])
  roles                    Role[]                        @relation("UserRoles")

  @@unique([schoolId, loginId])
  @@index([schoolId])
  @@index([userType])
  @@index([loginId])
}

model MarkAuditLog {
  id            String   @id @default(cuid())
  entityType    String
  entityId      String
  action        String
  previousValue Json?
  newValue      Json?
  performedById String
  performedAt   DateTime @default(now())
  ipAddress     String?
  userAgent     String?
  performedBy   User     @relation(fields: [performedById], references: [id])

  @@index([entityType, entityId])
  @@index([performedById])
  @@index([performedAt])
}

model School {
  id                   String                   @id @default(cuid())
  name                 String
  motto                String?
  slug                 String                   @unique
  code                 String                   @unique
  address              String?
  contact              String?
  contact2             String?
  contact3             String?
  email                String?
  email2               String?
  website              String?
  logo                 String?
  isActive             Boolean                  @default(true)
  primaryColor         String?
  accentColor          String?
  adminId              String
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @default(now())
  academicYears        AcademicYear[]
  appNotifications     AppNotification[]        @relation("SchoolAppNotifications")
  appraisalCycles      AppraisalCycle[]         @relation("SchoolAppraisalCycles")
  autoInvoiceConfigs   AutoInvoiceConfig[]
  bursaries            Bursary[]
  classTemplates       ClassTemplate[]
  departments          Department[]
  expenses             Expense[]
  expenseCategories    ExpenseCategory[]
  feeCategories        FeeCategory[]
  feeNotifications     FeeNotification[]
  feeStructures        FeeStructure[]
  gradingConfigs       GradingConfig[]
  libraryItems         LibraryItem[]
  messages             Message[]                @relation("SchoolMessages")
  notificationPrefs    NotificationPreference[] @relation("SchoolNotificationPrefs")
  parents              Parent[]
  payrolls             Payroll[]                @relation("SchoolPayrolls")
  payrollBatches       PayrollBatch[]           @relation("SchoolPayrollBatches")
  penaltyRules         PenaltyRule[]
  procurementOrders    ProcurementOrder[]
  projectWorks         ProjectWork[]
  admin                User                     @relation("SchoolAdmin", fields: [adminId], references: [id], onDelete: Cascade)
  assets               SchoolAsset[]
  billing              SchoolBilling?
  schoolDayConfigs     SchoolDayConfig[]
  events               SchoolEvent[]            @relation("SchoolEvents")
  staff                Staff[]                  @relation("SchoolStaff")
  staffNotices         StaffNotice[]            @relation("SchoolNotices")
  staffRoleDefinitions StaffRoleDefinition[]    @relation("SchoolStaffRoles")
  statutoryReports     StatutoryReport[]        @relation("SchoolStatutoryReports")
  stores               Store[]
  streams              Stream[]
  students             Student[]
  studentBursaries     StudentBursary[]
  studentFeeAccounts   StudentFeeAccount[]
  subjects             Subject[]
  subjectGradingScales SubjectGradingScale[]
  systemPayments       SystemPayment[]
  teachers             Teacher[]
  timetableVersions    TimetableVersion[]
  trainingPrograms     TrainingProgram[]        @relation("SchoolTrainingPrograms")
  users                User[]                   @relation("SchoolUsers")
  vehicles             Vehicle[]
  vendors              Vendor[]

  @@index([code])
  @@index([isActive])
}

model AcademicYear {
  id                   String                  @id @default(cuid())
  year                 String
  isActive             Boolean                 @default(true)
  startDate            DateTime?
  endDate              DateTime?
  schoolId             String
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @default(now())
  terms                AcademicTerm[]
  school               School                  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  autoInvoiceConfigs   AutoInvoiceConfig[]
  carryForwardLogsFrom CarryForwardLog[]       @relation("CarryForwardFromYear")
  carryForwardLogsTo   CarryForwardLog[]       @relation("CarryForwardToYear")
  classYears           ClassYear[]
  enrollments          Enrollment[]
  feeStructures        FeeStructure[]
  gradingConfigs       GradingConfig[]
  studentAttendances   StudentAttendance[]
  studentFeeAccounts   StudentFeeAccount[]
  teacherEnrollments   TeacherYearEnrollment[]
  timetableSlots       TimetableSlot[]
  timetableVersions    TimetableVersion[]

  @@unique([year, schoolId])
  @@index([schoolId])
  @@index([isActive])
}

model AcademicTerm {
  id                   String                  @id @default(cuid())
  name                 String
  termNumber           Int
  startDate            DateTime
  endDate              DateTime
  isActive             Boolean                 @default(true)
  academicYearId       String
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @default(now())
  academicYear         AcademicYear            @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  autoInvoiceConfigs   AutoInvoiceConfig[]
  carryForwardLogsFrom CarryForwardLog[]       @relation("CarryForwardFromTerm")
  carryForwardLogsTo   CarryForwardLog[]       @relation("CarryForwardToTerm")
  assessmentConfigs    ClassAssessmentConfig[]
  enrollments          Enrollment[]
  exams                Exam[]
  expenses             Expense[]
  feeStructures        FeeStructure[]
  lmsAssignments       LmsAssignment[]
  streamSubjects       StreamSubject[]
  studentAttendances   StudentAttendance[]
  studentFeeAccounts   StudentFeeAccount[]
  subjectResources     SubjectResource[]
  timetableSlots       TimetableSlot[]
  timetableVersions    TimetableVersion[]

  @@unique([termNumber, academicYearId])
  @@index([academicYearId])
  @@index([isActive])
}

model ClassTemplate {
  id          String      @id @default(cuid())
  name        String
  code        String?
  description String?
  level       Int?
  schoolId    String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @default(now())
  school      School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classYears  ClassYear[]

  @@unique([name, schoolId])
  @@unique([code, schoolId])
  @@index([schoolId])
  @@index([level])
}

model ClassYear {
  id                String                  @id @default(cuid())
  classTemplateId   String
  academicYearId    String
  maxStudents       Int?
  classTeacherId    String?
  remarks           String?
  isActive          Boolean                 @default(true)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @default(now())
  assessmentConfigs ClassAssessmentConfig[]
  dayConfigs        ClassDayConfig[]
  classSubjects     ClassSubject[]
  academicYear      AcademicYear            @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  classTemplate     ClassTemplate           @relation(fields: [classTemplateId], references: [id], onDelete: Cascade)
  enrollments       Enrollment[]
  exams             Exam[]
  feeStructures     FeeStructure[]
  streams           Stream[]

  @@unique([classTemplateId, academicYearId])
  @@index([academicYearId])
  @@index([classTemplateId])
  @@index([isActive])
}

model Stream {
  id             String                      @id @default(cuid())
  name           String
  classYearId    String
  schoolId       String
  classHeadId    String?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @default(now())
  enrollments    Enrollment[]
  transfersFrom  EnrollmentTransferHistory[] @relation("TransferFrom")
  transfersTo    EnrollmentTransferHistory[] @relation("TransferTo")
  lmsAssignments LmsAssignment[]             @relation("AssignmentStream")
  classHead      Teacher?                    @relation("StreamHead", fields: [classHeadId], references: [id])
  classYear      ClassYear                   @relation(fields: [classYearId], references: [id], onDelete: Cascade)
  school         School                      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  streamSubjects StreamSubject[]
  attendances    StudentAttendance[]
  resources      SubjectResource[]
  timetableSlots TimetableSlot[]

  @@unique([classYearId, name])
  @@index([classYearId])
  @@index([schoolId])
  @@index([classHeadId])
}

model Teacher {
  id                       String                        @id @default(cuid())
  staffNo                  String                        @unique
  firstName                String
  lastName                 String
  gender                   String
  status                   TeacherStatus                 @default(ACTIVE)
  dateOfBirth              DateTime
  nationality              String?
  nationalId               String?                       @unique
  maritalStatus            String?
  phone                    String                        @unique
  email                    String                        @unique
  address                  String?
  emergencyContactName     String?
  emergencyRelationship    String?
  emergencyPhone           String?
  emergencyEmail           String?
  qualification            String?
  specialization           String?
  teachingLevel            String?
  experienceYears          Int?
  previousSchools          String[]
  dateOfHire               DateTime
  employmentType           String
  role                     String
  currentStatus            TeacherStatus                 @default(ACTIVE)
  exitDate                 DateTime?
  exitReason               String?
  userId                   String                        @unique
  highestQualification     String?
  institutionAttended      String?
  professionalTraining     String?
  ongoingStudies           String?
  profilePhoto             String?
  documents                String?
  healthInfo               String?
  schoolId                 String
  createdAt                DateTime                      @default(now())
  updatedAt                DateTime                      @default(now())
  staffId                  String?                       @unique
  examMarksEntered         ExamMark[]                    @relation("ExamMarkEnteredBy")
  createdAssignments       LmsAssignment[]               @relation("AssignmentCreatedBy")
  gradedSubmissions        LmsSubmission[]               @relation("SubmissionGradedBy")
  headedStreams            Stream[]                      @relation("StreamHead")
  streamSubjectAssignments StreamSubjectTeacher[]
  assignmentsTakenOver     StreamSubjectTeacherHistory[] @relation("NewTeacher")
  assignmentHistory        StreamSubjectTeacherHistory[] @relation("PreviousTeacher")
  subjectHeadOf            Subject[]                     @relation("SubjectHead")
  uploadedResources        SubjectResource[]             @relation("ResourceUploadedBy")
  school                   School                        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  staff                    Staff?                        @relation("StaffTeacher", fields: [staffId], references: [id])
  user                     User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  availabilities           TeacherAvailability[]
  blockedSlots             TeacherBlockedSlot[]
  yearEnrollments          TeacherYearEnrollment[]

  @@index([schoolId])
  @@index([currentStatus])
  @@index([staffNo])
}

model TeacherYearEnrollment {
  id             String            @id @default(cuid())
  teacherId      String
  academicYearId String
  status         TeacherYearStatus @default(ACTIVE)
  startDate      DateTime          @default(now())
  endDate        DateTime?
  exitReason     String?
  remarks        String?
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @default(now())
  academicYear   AcademicYear      @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  teacher        Teacher           @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, academicYearId])
  @@index([teacherId])
  @@index([academicYearId])
  @@index([status])
  @@index([isActive])
}

model Subject {
  id             String                @id @default(cuid())
  name           String
  code           String?
  description    String?
  category       String?
  isActive       Boolean               @default(true)
  schoolId       String
  headTeacherId  String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  classSubjects  ClassSubject[]
  lmsAssignments LmsAssignment[]       @relation("AssignmentSubject")
  streamSubjects StreamSubject[]
  headTeacher    Teacher?              @relation("SubjectHead", fields: [headTeacherId], references: [id])
  school         School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  gradingScales  SubjectGradingScale[]
  resources      SubjectResource[]

  @@unique([schoolId, code])
  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([headTeacherId])
  @@index([isActive])
}

model ClassSubject {
  id             String              @id @default(cuid())
  subjectType    SubjectType         @default(COMPULSORY)
  classYearId    String
  subjectId      String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  classYear      ClassYear           @relation(fields: [classYearId], references: [id], onDelete: Cascade)
  subject        Subject             @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  timetableConfig ClassSubjectConfig?
  streamSubjects StreamSubject[]

  @@unique([classYearId, subjectId])
  @@index([classYearId])
  @@index([subjectId])
  @@index([subjectType])
}

model StreamSubject {
  id                 String                     @id @default(cuid())
  subjectType        SubjectType
  streamId           String
  subjectId          String
  classSubjectId     String
  termId             String
  isActive           Boolean                    @default(true)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  classSubject       ClassSubject               @relation(fields: [classSubjectId], references: [id], onDelete: Cascade)
  stream             Stream                     @relation(fields: [streamId], references: [id], onDelete: Cascade)
  subject            Subject                    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  term               AcademicTerm               @relation(fields: [termId], references: [id], onDelete: Cascade)
  teacherAssignments StreamSubjectTeacher[]
  studentEnrollments StudentSubjectEnrollment[]
  timetableSlots     TimetableSlot[]

  @@unique([streamId, subjectId, termId])
  @@index([streamId])
  @@index([subjectId])
  @@index([termId])
  @@index([classSubjectId])
  @@index([subjectType])
  @@index([streamId, termId, isActive])
}

model StreamSubjectTeacher {
  id                String                        @id @default(cuid())
  role              String                        @default("TEACHER")
  status            AssignmentStatus              @default(ACTIVE)
  streamSubjectId   String
  teacherId         String
  assignedDate      DateTime                      @default(now())
  assignedById      String?
  isReassignment    Boolean                       @default(false)
  reassignmentNotes String?
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt
  assignedBy        User?                         @relation("AssignmentCreatedBy", fields: [assignedById], references: [id])
  streamSubject     StreamSubject                 @relation(fields: [streamSubjectId], references: [id], onDelete: Cascade)
  teacher           Teacher                       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  history           StreamSubjectTeacherHistory[]

  @@unique([streamSubjectId, teacherId])
  @@index([streamSubjectId])
  @@index([teacherId])
  @@index([status])
  @@index([teacherId, status])
}

model StreamSubjectTeacherHistory {
  id                      String               @id @default(cuid())
  streamSubjectTeacherId  String
  previousTeacherId       String
  newTeacherId            String?
  reassignedDate          DateTime             @default(now())
  reassignedById          String?
  reason                  String
  previousAssignmentStart DateTime
  previousAssignmentEnd   DateTime
  studentsAffected        Int                  @default(0)
  notes                   String?
  createdAt               DateTime             @default(now())
  newTeacher              Teacher?             @relation("NewTeacher", fields: [newTeacherId], references: [id])
  previousTeacher         Teacher              @relation("PreviousTeacher", fields: [previousTeacherId], references: [id])
  reassignedBy            User?                @relation("ReassignedBy", fields: [reassignedById], references: [id])
  streamSubjectTeacher    StreamSubjectTeacher @relation(fields: [streamSubjectTeacherId], references: [id], onDelete: Cascade)

  @@index([streamSubjectTeacherId])
  @@index([previousTeacherId])
  @@index([newTeacherId])
  @@index([reassignedDate])
}

model Student {
  id                   String                @id @default(cuid())
  admissionNo          String
  linNumber            String?               @unique
  firstName            String
  lastName             String
  otherNames           String?
  dob                  DateTime
  gender               String
  bloodGroup           String?
  NIN                  String?               @unique
  nationality          String
  village              String?
  religion             String?
  imageUrl             String?
  admissionDate        DateTime              @default(now())
  previousSchool       String?
  userId               String?               @unique
  parentId             String
  medicalConditions    String?
  disability           String?
  schoolId             String
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @default(now())
  enrollments          Enrollment[]
  libraryBorrows       LibraryBorrow[]
  lmsSubmissions       LmsSubmission[]       @relation("SubmissionStudent")
  projectWorks         ProjectWork[]
  parent               Parent                @relation(fields: [parentId], references: [id])
  school               School                @relation(fields: [schoolId], references: [id])
  user                 User?                 @relation(fields: [userId], references: [id])
  attendances          StudentAttendance[]
  studentBursaries     StudentBursary[]
  feeAccounts          StudentFeeAccount[]
  transportAssignments TransportAssignment[] @relation("StudentTransport")

  @@unique([admissionNo, schoolId])
  @@index([schoolId])
  @@index([parentId])
  @@index([isActive])
}

model Enrollment {
  id                 String                      @id @default(cuid())
  studentId          String
  classYearId        String
  streamId           String?
  academicYearId     String
  termId             String
  enrollmentType     EnrollmentType              @default(CONTINUING)
  status             EnrollmentStatus            @default(ACTIVE)
  promotedFromId     String?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @default(now())
  academicYear       AcademicYear                @relation(fields: [academicYearId], references: [id])
  classYear          ClassYear                   @relation(fields: [classYearId], references: [id])
  promotedFrom       Enrollment?                 @relation("EnrollmentProgression", fields: [promotedFromId], references: [id])
  promotedTo         Enrollment[]                @relation("EnrollmentProgression")
  stream             Stream?                     @relation(fields: [streamId], references: [id])
  student            Student                     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term               AcademicTerm                @relation(fields: [termId], references: [id])
  transferHistory    EnrollmentTransferHistory[]
  reportCard         ReportCard?
  subjectEnrollments StudentSubjectEnrollment[]

  @@unique([studentId, termId])
  @@index([studentId, academicYearId])
  @@index([classYearId, streamId, termId])
  @@index([classYearId])
  @@index([status])
  @@index([streamId, termId, status])
}

model EnrollmentTransferHistory {
  id              String     @id @default(cuid())
  enrollmentId    String
  fromStreamId    String
  toStreamId      String
  reason          String?
  transferredAt   DateTime   @default(now())
  transferredById String?
  enrollment      Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  fromStream      Stream     @relation("TransferFrom", fields: [fromStreamId], references: [id])
  toStream        Stream     @relation("TransferTo", fields: [toStreamId], references: [id])
  transferredBy   User?      @relation(fields: [transferredById], references: [id])

  @@index([enrollmentId])
  @@index([fromStreamId])
  @@index([toStreamId])
  @@index([transferredAt])
}

model Parent {
  id           String    @id @default(cuid())
  firstName    String
  name         String
  lastName     String
  title        String?
  relationship String?
  gender       String?
  dob          DateTime?
  phone        String    @unique
  altNo        String?
  email        String?   @unique
  idNo         String?   @unique
  occupation   String?
  address      String?
  village      String?
  country      String?
  religion     String?
  userId       String    @unique
  imageUrl     String?
  schoolId     String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now())
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  students     Student[]

  @@index([schoolId])
  @@index([userId])
}

model StudentSubjectEnrollment {
  id               String                  @id @default(cuid())
  enrollmentId     String
  streamSubjectId  String
  enrolledAt       DateTime                @default(now())
  enrolledById     String?
  status           SubjectEnrollmentStatus @default(ACTIVE)
  isCompulsory     Boolean                 @default(true)
  isAutoEnrolled   Boolean                 @default(false)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  examMarks        ExamMark[]
  marks            Mark[]
  enrollment       Enrollment              @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  streamSubject    StreamSubject           @relation(fields: [streamSubjectId], references: [id], onDelete: Cascade)
  subjectFinalMark SubjectFinalMark?
  subjectResult    SubjectResult?

  @@unique([enrollmentId, streamSubjectId])
  @@index([streamSubjectId])
  @@index([enrollmentId])
  @@index([status])
  @@index([isCompulsory])
  @@index([streamSubjectId, status])
}

model Exam {
  id          String       @id @default(cuid())
  name        String
  examType    ExamType
  date        DateTime?
  maxMarks    Int          @default(100)
  termId      String
  classYearId String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now())
