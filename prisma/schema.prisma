  reversals           FeeTransaction[]  @relation("TransactionReversal")
  studentFeeAccount   StudentFeeAccount @relation(fields: [studentFeeAccountId], references: [id], onDelete: Cascade)

  @@index([studentFeeAccountId])
  @@index([transactionType])
  @@index([referenceNumber])
  @@index([createdAt])
  @@index([paymentMethod])
  @@index([isReversal])
}

