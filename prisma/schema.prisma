  reversedAt          DateTime?
  reversedById        String?
  reversalOfId        String?
  processedAt         DateTime          @default(now())
  createdById         String?
  createdAt           DateTime          @default(now())
  receipt             FeeReceipt?
  createdBy           User?             @relation("FeeTransactionCreatedBy", fields: [createdById], references: [id])
  invoice             Invoice?          @relation(fields: [invoiceId], references: [id])
