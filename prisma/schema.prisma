  teacherId          String?
  subjectId          String?
  isResolved         Boolean          @default(false)
  resolvedAt         DateTime?
  createdAt          DateTime         @default(now())
  timetableVersion   TimetableVersion @relation(fields: [timetableVersionId], references: [id], onDelete: Cascade)

  @@index([timetableVersionId])
  @@index([severity])
  @@index([isResolved])
}

model SchoolBilling {
  id           String   @id @default(cuid())
  schoolId     String   @unique
  pricePerTerm Float
  currency     String   @default("UGX")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model BillingTerm {
  id        String          @id @default(cuid())
  name      String          @unique
  startDate DateTime
  endDate   DateTime
  createdAt DateTime        @default(now())
  payments  SystemPayment[]
}

model SystemPayment {
  id            String      @id @default(cuid())
  schoolId      String
  termId        String
  amountPaid    Float
  currency      String      @default("UGX")
  paidAt        DateTime    @default(now())
  note          String?
  receiptNumber String      @unique
  createdAt     DateTime    @default(now())
  school        School      @relation(fields: [schoolId], references: [id])
  term          BillingTerm @relation(fields: [termId], references: [id])

  @@index([schoolId])
  @@index([termId])
  @@index([paidAt])
}

model SystemExpense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  currency    String   @default("UGX")
  category    String   @default("SERVER")
  paidAt      DateTime
  createdAt   DateTime @default(now())

  @@index([paidAt])
  @@index([category])
}

model ProjectWork {
  id           String   @id @default(cuid())
  studentId    String
  schoolId     String
  title        String
  description  String?
  fileUrl      String
  fileKey      String
  fileName     String
  fileSizeKb   Int?
  className    String?
  streamName   String?
  academicYear String?
  termName     String?
  uploadedById String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation("ProjectWorkUploadedBy", fields: [uploadedById], references: [id])

  @@index([studentId])
  @@index([schoolId])
  @@index([uploadedById])
}

model StudentAttendance {
  id             String                  @id @default(cuid())
  studentId      String
  streamId       String
  academicYearId String
  termId         String
  schoolId       String
  date           DateTime
  status         StudentAttendanceStatus @default(ABSENT)
  notes          String?
  markedById     String
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  academicYear   AcademicYear            @relation(fields: [academicYearId], references: [id])
  markedBy       User                    @relation("AttendanceMarkedBy", fields: [markedById], references: [id])
  stream         Stream                  @relation(fields: [streamId], references: [id])
  student        Student                 @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term           AcademicTerm            @relation(fields: [termId], references: [id])

  @@unique([studentId, date])
  @@index([streamId, date])
  @@index([studentId])
  @@index([schoolId])
  @@index([termId, streamId])
}

model SubjectResource {
  id           String        @id @default(cuid())
  title        String
  description  String?
  type         ResourceType  @default(NOTES)
  fileUrl      String
  fileKey      String
  fileName     String
  fileSize     Int?
  subjectId    String
  streamId     String?
  termId       String?
  schoolId     String
  uploadedById String
  isPublished  Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  stream       Stream?       @relation(fields: [streamId], references: [id])
  subject      Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  term         AcademicTerm? @relation(fields: [termId], references: [id])
  uploadedBy   Teacher       @relation("ResourceUploadedBy", fields: [uploadedById], references: [id])

  @@index([subjectId])
  @@index([streamId])
  @@index([schoolId])
  @@index([uploadedById])
  @@index([type])
}

model LmsAssignment {
  id          String          @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime
  streamId    String
  subjectId   String
  termId      String?
  schoolId    String
  createdById String
  maxScore    Float?          @default(100)
  isPublished Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdBy   Teacher         @relation("AssignmentCreatedBy", fields: [createdById], references: [id])
  stream      Stream          @relation("AssignmentStream", fields: [streamId], references: [id], onDelete: Cascade)
  subject     Subject         @relation("AssignmentSubject", fields: [subjectId], references: [id], onDelete: Cascade)
  term        AcademicTerm?   @relation(fields: [termId], references: [id])
  submissions LmsSubmission[]

  @@index([streamId, subjectId])
  @@index([schoolId])
  @@index([createdById])
  @@index([termId])
  @@index([dueDate])
}

model LmsSubmission {
  id           String           @id @default(cuid())
  assignmentId String
  studentId    String
  fileUrl      String
  fileKey      String
  fileName     String
  fileSize     Int?
  status       SubmissionStatus @default(SUBMITTED)
  score        Float?
  feedback     String?
  gradedById   String?
  gradedAt     DateTime?
  submittedAt  DateTime         @default(now())
  schoolId     String
  assignment   LmsAssignment    @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  gradedBy     Teacher?         @relation("SubmissionGradedBy", fields: [gradedById], references: [id])
  student      Student          @relation("SubmissionStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
  @@index([schoolId])
  @@index([status])
}

